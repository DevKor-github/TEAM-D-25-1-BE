generator client {
  provider = "prisma-client-js"
  binaryTargets   = ["native"]
}

datasource db { 
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum FollowerStatus {
  PENDING
  ACCEPTED
  REJECTED
  BANNED
}

enum SocialProvider {
  KAKAO
  GOOGLE
  APPLE
}

enum Mbti {
  ESTJ
  INFP
  ISFP
  INTJ
  ENTJ
  ISFJ
  ESFP
  ISTP
  INFJ
  ENTP
  ISTJ
  ESTP
  ENFJ
  ESFJ
  ENFP
  INTP
}

enum Tag {
  // StyleTag
  DRINKER
  VEGAN_OR_VEGETARIAN
  SPICY_FOOD_LOVER
  PICKY_EATER
  DESSERT_LOVER
  DIETER
  LATE_NIGHT_EATER
  SWEET_TOOTH
  HEALTH_CONSCIOUS
  VALUE_SEEKER
  MEAT_LOVER
  DIET_PLANNER
  CAFFEINE_ADDICT
  CLASSIC_TASTE
  STREET_FOOD_FAN
  TTEOKBOKKI_LOVER
  SMALL_EATER
  BIG_EATER
  SOLO_DINER
  SEAFOOD_LOVER
  HEARTY_EATER

  // FoodTag
  STEAK
  BREAD
  HAMBURGER
  CHICKEN
  GOPCHANG
  PASTA
  SHABU_SHABU
  SOJU
  SUSHI
  GUKBAP
  DESSERT
  COFFEE
  KIMCHI_JJIGAE
  PIZZA
  RAMEN
  DONKATSU
}

model User {
  id               String             @id @default(uuid())
  email            String             @unique
  username         String             @unique
  nickname         String?
  description      String?
  password         String?
  socialProvider   String?
  socialId         String?
  isPrivate        Boolean            @default(false)
  status           String             @default("ACTIVE")
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  firebaseUid      String?             @unique
  savedRestaurants SavedRestaurant[]
  socialLogin      SocialLogin[]
  isOnboarded      Boolean
  profileImageUrl  String?
  fcmToken         String?
  fcmTokenUpdatedAt DateTime?
  lastWatered      DateTime?
  tag              Tag[]
  mbti             Mbti?
}

model SocialLogin {
  id               String  @id      @default(uuid())
  user             User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId           String  @unique
  provider         SocialProvider
  providerUserId   String
  profile          String?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([userId])
  @@unique([provider, providerUserId])
}


model Restaurant {
  id        String            @id @default(uuid())
  placeId   String            @unique //지도 API 식별자 저장용
  name      String
  address   String
  latitude  Float
  longitude Float
  createdAt DateTime          @default(now())
  tags      String[]
  savedBy   SavedRestaurant[]
}

model SavedRestaurant {
  // id String @db.Uuid @id

  user                User       @relation(fields: [userId], references: [id])
  userId              String

  restaurant          Restaurant @relation(fields: [restaurantId], references: [id])
  restaurantId        String

  review              String?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt
  recommendedByUsers  String[]
  treeType            Int
  tag                 Tag[]
  images              String[]

  @@id([userId,restaurantId])
}


model Follower {
  userId     String @db.Uuid 
  followerId  String @db.Uuid
  status     FollowerStatus @default(PENDING)
  createdAt  DateTime     @default(now())

  @@id([userId, followerId])
  @@index([followerId]) 
}

model SearchRestaurantTag {
  id String @id
  restaurantId String @db.Uuid
  name String // Info: varchar_pattern_ops

  @@index([restaurantId])
  @@index([name])
}

model SearchUserTag {
  id String @id 
  userId String @db.Uuid
  name String // Info: varchar_pattern_ops 

  @@index([userId])
  @@index([name])
}
